<form class="dnd-animal-ui-config">
  {{#if isGM}}
  <section class="dnd-animal-ui-config-section">
    <h3><i class="fas fa-leaf"></i> {{localize "DNDANIMALUI.Config.SectionTheme"}}</h3>

    <label class="dnd-animal-ui-config-row">
      <span>
        <strong>{{localize "DNDANIMALUI.Settings.EnableTheme.Name"}}</strong>
        <small>{{localize "DNDANIMALUI.Settings.EnableTheme.Hint"}}</small>
      </span>
      <input type="checkbox" name="enableTheme" {{#if enableTheme}}checked{{/if}}>
    </label>

    <label class="dnd-animal-ui-config-row">
      <span>
        <strong>{{localize "DNDANIMALUI.Settings.CompatMode.Name"}}</strong>
        <small>{{localize "DNDANIMALUI.Settings.CompatMode.Hint"}}</small>
      </span>
      <input type="checkbox" name="compatMode" {{#if compatMode}}checked{{/if}}>
    </label>

    <label class="dnd-animal-ui-config-row">
      <span>
        <strong>{{localize "DNDANIMALUI.Settings.EnableStickers.Name"}}</strong>
        <small>{{localize "DNDANIMALUI.Settings.EnableStickers.Hint"}}</small>
      </span>
      <input type="checkbox" name="enableStickers" {{#if enableStickers}}checked{{/if}}>
    </label>
  </section>

  <section class="dnd-animal-ui-config-section">
    <h3><i class="fas fa-palette"></i> {{localize "DNDANIMALUI.Config.SectionCompat"}}</h3>

    <label class="dnd-animal-ui-config-row">
      <span>
        <strong>{{localize "DNDANIMALUI.Settings.EnableFolderSoftening.Name"}}</strong>
        <small>{{localize "DNDANIMALUI.Settings.EnableFolderSoftening.Hint"}}</small>
      </span>
      <input type="checkbox" name="enableFolderSoftening" {{#if enableFolderSoftening}}checked{{/if}}>
    </label>

    <label class="dnd-animal-ui-config-row">
      <span>
        <strong>{{localize "DNDANIMALUI.Settings.EnableJournalReadability.Name"}}</strong>
        <small>{{localize "DNDANIMALUI.Settings.EnableJournalReadability.Hint"}}</small>
      </span>
      <input type="checkbox" name="enableJournalReadability" {{#if enableJournalReadability}}checked{{/if}}>
    </label>

    <label class="dnd-animal-ui-config-row">
      <span>
        <strong>{{localize "DNDANIMALUI.Settings.EnableDnd5eSheetSafety.Name"}}</strong>
        <small>{{localize "DNDANIMALUI.Settings.EnableDnd5eSheetSafety.Hint"}}</small>
      </span>
      <input type="checkbox" name="enableDnd5eSheetSafety" {{#if enableDnd5eSheetSafety}}checked{{/if}}>
    </label>

    <label class="dnd-animal-ui-config-row">
      <span>
        <strong>{{localize "DNDANIMALUI.Settings.EnableDnd5eAnimalBackground.Name"}}</strong>
        <small>{{localize "DNDANIMALUI.Settings.EnableDnd5eAnimalBackground.Hint"}}</small>
      </span>
      <input type="checkbox" name="enableDnd5eAnimalBackground" {{#if enableDnd5eAnimalBackground}}checked{{/if}}>
    </label>
  </section>

  <section class="dnd-animal-ui-config-section">
    <h3><i class="fas fa-icons"></i> {{localize "DNDANIMALUI.Config.SectionStickers"}}</h3>
    <p class="dnd-animal-ui-config-hint">{{localize "DNDANIMALUI.Config.StickersHint"}}</p>

    <div class="dnd-animal-ui-custom-sticker-list">
      {{#each customStickers}}
      <div class="dnd-animal-ui-custom-sticker-row" data-custom-sticker-row>
        <input type="text" data-sticker-field="label" value="{{label}}" placeholder="{{localize "DNDANIMALUI.Config.StickerLabel"}}">
        <input type="text" data-sticker-field="command" value="{{command}}" placeholder="{{localize "DNDANIMALUI.Config.StickerCommand"}}">
        <select data-sticker-field="category">
          {{#each categoryOptions}}
            <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
        <input type="text" data-sticker-field="path" value="{{path}}" placeholder="{{localize "DNDANIMALUI.Config.StickerImage"}}">
        <button type="button" data-action="pick-sticker-image" title="{{localize "DNDANIMALUI.Config.Browse"}}">
          <i class="fas fa-file-image"></i>
        </button>
        <button type="button" data-action="delete-sticker" title="{{localize "DNDANIMALUI.Config.Delete"}}">
          <i class="fas fa-trash"></i>
        </button>
      </div>
      {{/each}}
    </div>

    <button type="button" class="dnd-animal-ui-add-sticker" data-action="add-sticker">
      <i class="fas fa-plus"></i>
      {{localize "DNDANIMALUI.Config.AddSticker"}}
    </button>
  </section>

  <section class="dnd-animal-ui-config-section">
    <h3><i class="fas fa-columns"></i> {{localize "DNDANIMALUI.Config.SectionSidebar"}}</h3>

    <label class="dnd-animal-ui-config-row">
      <span>
        <strong>{{localize "DNDANIMALUI.Settings.EnableSidebarVisibility.Name"}}</strong>
        <small>{{localize "DNDANIMALUI.Settings.EnableSidebarVisibility.Hint"}}</small>
      </span>
      <input type="checkbox" name="enableSidebarVisibility" {{#if enableSidebarVisibility}}checked{{/if}}>
    </label>

    <div class="dnd-animal-ui-sidebar-tabs-list">
      <div class="dnd-animal-ui-sidebar-tab-row header-row">
        <span class="tab-icon"></span>
        <span class="tab-name">{{localize "DNDANIMALUI.Config.SidebarTab"}}</span>
        <span class="tab-visible">{{localize "DNDANIMALUI.Config.SidebarVisible"}}</span>
      </div>
      {{#each tabs}}
        <label class="dnd-animal-ui-sidebar-tab-row" data-tab-id="{{id}}">
          <span class="tab-icon"><i class="{{icon}}"></i></span>
          <span class="tab-name">{{label}}</span>
          <span class="tab-visible">
            <input type="checkbox" name="visible-{{id}}" data-sidebar-tab-id="{{id}}" {{#if checked}}checked{{/if}}>
          </span>
        </label>
      {{/each}}
    </div>
  </section>
  {{/if}}

  <section class="dnd-animal-ui-config-section">
    <h3><i class="fas fa-user"></i> {{localize "DNDANIMALUI.Config.SectionPersonal"}}</h3>
    <p class="dnd-animal-ui-config-hint">{{localize "DNDANIMALUI.Config.PersonalHint"}}</p>

    <label class="dnd-animal-ui-config-row">
      <span>
        <strong>{{localize "DNDANIMALUI.Settings.EnableCursor.Name"}}</strong>
        <small>{{localize "DNDANIMALUI.Settings.EnableCursor.Hint"}}</small>
      </span>
      <input type="checkbox" name="enableCursor" {{#if enableCursor}}checked{{/if}}>
    </label>

    <label class="dnd-animal-ui-config-row">
      <span>
        <strong>{{localize "DNDANIMALUI.Settings.EnableButtonPressFx.Name"}}</strong>
        <small>{{localize "DNDANIMALUI.Settings.EnableButtonPressFx.Hint"}}</small>
      </span>
      <input type="checkbox" name="enableButtonPressFx" {{#if enableButtonPressFx}}checked{{/if}}>
    </label>

    <label class="dnd-animal-ui-config-row">
      <span>
        <strong>{{localize "DNDANIMALUI.Settings.AssetIntensity.Name"}}</strong>
        <small>{{localize "DNDANIMALUI.Settings.AssetIntensity.Hint"}}</small>
      </span>
      <select name="assetIntensity">
        {{#each assetIntensityOptions}}
          <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
        {{/each}}
      </select>
    </label>
  </section>

  <footer class="sheet-footer flexrow">
    <button type="submit">
      <i class="fas fa-save"></i>
      {{localize "DNDANIMALUI.Config.Save"}}
    </button>
    {{#if isGM}}
    <button type="button" data-action="select-all">
      <i class="fas fa-check-double"></i>
      {{localize "DNDANIMALUI.Config.SelectAll"}}
    </button>
    <button type="button" data-action="hide-compendium">
      <i class="fas fa-atlas"></i>
      {{localize "DNDANIMALUI.Config.HideCompendiumOnly"}}
    </button>
    <button type="button" data-action="select-none">
      <i class="fas fa-ban"></i>
      {{localize "DNDANIMALUI.Config.SelectNone"}}
    </button>
    {{/if}}
  </footer>
</form>
